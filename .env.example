# =============================================================================
# Astroledger — environment variables (copy to .env and fill in)
# =============================================================================
# Anything marked REQUIRED must be set before `npm run dev` will work.
# Optional integrations gracefully no-op when unset.
# Connector credentials marked "stored encrypted in DB" are pasted into the UI
# at /connect, not into this file — they end up AES-256-GCM encrypted at rest.


# -----------------------------------------------------------------------------
# 1. DATABASE  (REQUIRED)
# -----------------------------------------------------------------------------
# SQLite by default. To switch to Postgres, change the provider in
# prisma/schema.prisma and use postgresql://user:pass@host:5432/astroledger here.
DATABASE_URL="file:./dev.db"

# Full database encryption is mandatory in production and fails closed if the
# driver or key is unavailable. Prefer a root-managed key file mounted read-only
# into the container; SQLCIPHER_KEY remains a development-only fallback.
ASTROLEDGER_DB_ENCRYPTED=true
ASTROLEDGER_DB_KEY_FILE=/run/secrets/astroledger/db.key
# SQLCIPHER_KEY=


# -----------------------------------------------------------------------------
# 2. FIELD-LEVEL ENCRYPTION  (REQUIRED in production)
# -----------------------------------------------------------------------------
# AES-256-GCM key used to encrypt sensitive columns at rest:
#   • Plaid access tokens
#   • SimpleFIN access URLs (with embedded credentials)
#   • PayPal client_id + secret
#   • Raw order/email bodies
#
# Without this set, a dev-only fallback key is used — NOT secure. Generate one:
#   npx tsx scripts/new-master-key.ts
#
# If MASTER_KEY is not 64 hex chars, it's treated as a passphrase and scrypt'd.
# The vault that holds this key is locked on server boot and only unlocked
# after a successful user sign-in.
# Prefer the file form in production. MASTER_KEY remains a dev fallback.
ASTROLEDGER_MASTER_KEY_FILE=/run/secrets/astroledger/master.key
# MASTER_KEY=

# Automated backups and pre-migration snapshots are always AES-256-GCM wrapped
# in production. Keep this key distinct from both database and field keys.
ASTROLEDGER_BACKUP_KEY_FILE=/run/secrets/astroledger/backup.key
# ASTROLEDGER_BACKUP_KEY=
ASTROLEDGER_BACKUP_SCRATCH_DIR=/run/astroledger-backup

# Persistent encrypted receipt and demo-sandbox storage.
ASTROLEDGER_UPLOADS_DIR=/data/uploads
ASTROLEDGER_SANDBOX_DIR=/data/sandboxes


# -----------------------------------------------------------------------------
# 3. AUTH.JS  (REQUIRED)
# -----------------------------------------------------------------------------
# Session-cookie signing secret. Generate:
#   node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
AUTH_SECRET=

# Public URL Auth.js uses for OAuth callbacks. In prod set to your real https URL
# (e.g. https://astroledger.example.com behind Cloudflare Tunnel — see docs/CLOUDFLARE_TUNNEL.md).
# Auth.js v5 prefers AUTH_URL; NEXTAUTH_URL works as a legacy alias. Either is fine.
AUTH_URL=http://localhost:5050
NEXTAUTH_URL=http://localhost:5050

# When deployed behind a reverse proxy / tunnel at a public hostname, set this
# so Next.js server actions accept cross-origin POSTs from your real domain.
# Leave blank for pure-localhost dev.
# ASTROLEDGER_PUBLIC_HOST=astroledger.example.com

# Cloudflare Tunnel token. Required only when running
# `docker compose --profile tunnel up -d cloudflared`. Get from
# Cloudflare Zero Trust → Tunnels → your tunnel → connector token.
# See docs/CLOUDFLARE_TUNNEL.md for the full setup.
# CF_TUNNEL_TOKEN=eyJhIjoi...

# Optional HARD allowlist of emails permitted to sign in.
# If unset (default), Astroledger uses TOFU: the first successful Google sign-in
# becomes the admin, and only existing User rows can sign in after that.
# Set this for belt-and-suspenders mode (e.g. server-side-only allowlist).
# ALLOWED_EMAILS=you@example.com,partner@example.com

# Optional additional instance administrators, comma-separated.
# The first user who ever signed in is always the admin (self-healing: if an
# instance somehow has no admin, the earliest-created account is promoted on
# its next session). Anyone listed here is ALSO promoted to admin on sign-in.
# Admins manage backups, updates, Gmail auto-sync, and the LLM provider.
# ADMIN_EMAILS=partner@example.com


# -----------------------------------------------------------------------------
# 4. GOOGLE OAUTH + GMAIL  (REQUIRED for sign-in; powers Gmail receipt sync)
# -----------------------------------------------------------------------------
# Create at: https://console.cloud.google.com/apis/credentials
#   1. Create project → "Astroledger"
#   2. APIs & Services → Library → enable "Gmail API"
#   3. OAuth consent screen → External, add yourself as test user
#   4. Credentials → Create OAuth client ID → Web application
#       Authorized JavaScript origins: http://localhost:5050
#       Authorized redirect URIs:      http://localhost:5050/api/auth/callback/google
#   5. Paste the client ID + secret below
#
# Scopes requested: openid, email, profile, gmail.readonly (asked at consent).
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=


# -----------------------------------------------------------------------------
# 5. WEBAUTHN / PASSKEYS  (REQUIRED if you want passkey sign-in)
# -----------------------------------------------------------------------------
# Relying-party domain shown in the OS passkey prompt. Use 'localhost' for dev;
# in production this MUST match your public domain exactly (no scheme, no port).
# Passkeys are domain-bound — a passkey enrolled on localhost won't work on
# astroledger.example.com and vice versa. After switching to a tunnel, re-enroll.
WEBAUTHN_RP_ID=localhost
WEBAUTHN_ORIGIN=http://localhost:5050


# =============================================================================
# 6. BANK / WALLET CONNECTORS — pick any (or all)
# =============================================================================
# Note: SimpleFIN and PayPal don't need any env vars — you paste credentials
# directly into the UI at /connect, and Astroledger encrypts them with MASTER_KEY.

# -----------------------------------------------------------------------------
# 6a. SIMPLEFIN BRIDGE  (recommended for personal use, ~$1.50/yr)
# -----------------------------------------------------------------------------
# 1. https://beta-bridge.simplefin.org/ → sign up → connect your banks
# 2. Click "Setup Token" → paste it in Astroledger at /connect → SimpleFIN card
# Astroledger exchanges the token for a long-lived Access URL and encrypts it.
# No env vars required.

# -----------------------------------------------------------------------------
# 6b. PLAID  (real banks via OAuth Link UI; free dev tier covers 100 items)
# -----------------------------------------------------------------------------
# 1. https://dashboard.plaid.com/signup → confirm email
# 2. Team Settings → Keys → copy client_id + secret for your env
# 3. PLAID_ENV: sandbox (fake data), development (FREE real banks, no time limit),
#    production (~$0.30/account/mo + Plaid application)
# Sandbox login (fake): user_good / pass_good
PLAID_CLIENT_ID=
PLAID_SECRET=
PLAID_ENV=development            # sandbox | development | production
PLAID_PRODUCTS=transactions      # transactions, accounts, identity, investments, liabilities
PLAID_COUNTRY_CODES=US           # US, CA, GB, etc.

# -----------------------------------------------------------------------------
# 6c. PAYPAL  (Business accounts only — Personal accounts use CSV import)
# -----------------------------------------------------------------------------
# 1. https://developer.paypal.com/dashboard/applications/  (PayPal Business)
# 2. Apps & Credentials → Create App → "Live" (or Sandbox for testing)
# 3. Enable feature: "Transaction Search"
# 4. Paste Client ID + Secret in the UI at /connect → PayPal card
# Astroledger validates the creds, then stores them encrypted in your local DB.
# No env vars required (Sandbox toggle lives in the UI form too).
# Personal PayPal users: paypal.com → Activity → Download → CSV → use the
# generic CSV importer at /connect.


# -----------------------------------------------------------------------------
# 7. LOCAL LLM  (OPTIONAL — powers Spacer chat + auto-categorization)
# -----------------------------------------------------------------------------
# These env vars are the FALLBACK config — used when no LLM provider has
# been configured in Settings → AI. Once you pick a provider in the UI, those
# choices override the env vars.
#
# Providers supported via the Settings UI (and via direct env override below):
#   • Ollama (local, default)         — set OLLAMA_BASE_URL
#   • OpenAI                          — set OPENAI_API_KEY + Settings: kind=openai
#   • Anthropic                       — set ANTHROPIC_API_KEY + Settings: kind=anthropic
#   • Any OpenAI-compatible endpoint  — Settings: kind=custom, base_url=...
#                                       (LM Studio, vLLM, llama.cpp, OpenRouter, Groq)
#   • Disabled                        — Settings: kind=disabled (no chat / no auto-cat)
#
# API keys live in env vars (never in the DB). The Settings UI stores the
# env var NAME so Astroledger knows which one to read at call time.
OLLAMA_BASE_URL=http://localhost:11434/v1
OPENAI_API_KEY=ollama

# Optional: cloud provider keys (only needed if you pick that kind in Settings)
# OPENAI_API_KEY=sk-...
# ANTHROPIC_API_KEY=sk-ant-...

# Models. Defaults sized for RTX 2070 SUPER (8 GB VRAM) + Ryzen 9 9900X + 32 GB RAM.
# Install with: ollama pull <model>
LLM_MODEL=qwen2.5:14b-instruct-q4_K_M       # default chat (15–25 tok/s)
LLM_FAST_MODEL=llama3.1:8b-instruct-q5_K_M  # fast model for auto-categorization


# -----------------------------------------------------------------------------
# 8. OLLAMA DOCKER ORCHESTRATION  (OPTIONAL — auto-start LLM on demand)
# -----------------------------------------------------------------------------
# When true, Astroledger runs `docker compose --profile llm up -d ollama` on first
# chat request and stops the container after LLM_AUTO_STOP_AFTER_MS of idle.
# Requires Docker Desktop with NVIDIA Container Toolkit (WSL2 backend).
AUTO_START_LLM=true
LLM_AUTO_STOP_AFTER_MS=600000   # 10 minutes


# -----------------------------------------------------------------------------
# Gmail auto-sync  (UI-driven, no env vars)
# -----------------------------------------------------------------------------
# Configure in the UI at /settings → "Gmail auto-sync" card:
#   • Toggle on/off
#   • Interval (5–1440 min, default 60)
#   • Max receipts per run (1–500, default 50)
#   • Lookback window (1–365 days, default 7)
#   • Use local LLM to flag new subscriptions (uses LLM_MODEL above)
# Persisted in the database (AppSetting rows) and survives restarts.
# The scheduler boots automatically via src/instrumentation.ts.


# =============================================================================
# FUTURE INTEGRATIONS — slots reserved, no code reads these yet
# =============================================================================

# -----------------------------------------------------------------------------
# 9. MICROSOFT OUTLOOK / GRAPH  (FUTURE — Outlook receipt sync)
# -----------------------------------------------------------------------------
# Create at: https://portal.azure.com/ → App registrations → New registration
#   - Supported account types: "Personal Microsoft accounts only"
#   - Redirect URI (Web): http://localhost:5050/api/auth/callback/microsoft
#   - API permissions: Microsoft Graph → Mail.Read (delegated)
#   - Certificates & secrets → New client secret → copy value
MICROSOFT_CLIENT_ID=
MICROSOFT_CLIENT_SECRET=
MICROSOFT_TENANT=consumers       # 'consumers' for personal accounts


# -----------------------------------------------------------------------------
# 10. INFLATION / CPI DATA  (FUTURE — long-term forecasting)
# -----------------------------------------------------------------------------
# Used for 13–60 month forecast extrapolation. Default is hardcoded 3.5%/yr;
# override with a real CPI feed if you want live data.
# Free at: https://www.bls.gov/developers/  (US Bureau of Labor Statistics)
BLS_API_KEY=
INFLATION_DEFAULT=0.035          # 3.5% annual, used when BLS_API_KEY absent


# -----------------------------------------------------------------------------
# 11. EXCHANGE RATES  (FUTURE — multi-currency support)
# -----------------------------------------------------------------------------
# Free tier: https://openexchangerates.org/signup/free  (1000 req/mo)
# Or: https://exchangerate.host  (no key required, MIT-licensed)
OPENEXCHANGERATES_APP_ID=


# -----------------------------------------------------------------------------
# 12. STRIPE WEBHOOK  (FUTURE — verify Stripe-powered receipt emails)
# -----------------------------------------------------------------------------
# Not for payment processing — for verifying Stripe receipt signatures so
# parsed receipts can be marked "verified" vs "heuristic".
# https://dashboard.stripe.com/webhooks  → endpoint signing secret
STRIPE_WEBHOOK_SECRET=


# -----------------------------------------------------------------------------
# 13. PUSH NOTIFICATIONS  (FUTURE — alerts/budget warnings)
# -----------------------------------------------------------------------------
# Web Push (VAPID). Generate keypair: npx web-push generate-vapid-keys
VAPID_PUBLIC_KEY=
VAPID_PRIVATE_KEY=
VAPID_SUBJECT=mailto:you@example.com


# -----------------------------------------------------------------------------
# 14. SENTRY  (FUTURE — error tracking)
# -----------------------------------------------------------------------------
# https://sentry.io/  → New project → Next.js → copy DSN
SENTRY_DSN=
SENTRY_AUTH_TOKEN=


# -----------------------------------------------------------------------------
# 15. CRON / SCHEDULED JOBS  (FUTURE — external triggers for sync/checkpoint)
# -----------------------------------------------------------------------------
# Secret for /api/cron/* endpoints so external cron services can hit them
# without going through Auth.js. Generate: openssl rand -hex 32
CRON_SECRET=


# -----------------------------------------------------------------------------
# 16. STOCK / INVESTMENT PRICES  (FUTURE — net-worth investment tracking)
# -----------------------------------------------------------------------------
# Plaid covers brokerage balances. For real-time prices outside Plaid:
# Alpha Vantage:   https://www.alphavantage.co/support/#api-key  (free, 25 req/day)
# Polygon.io:      https://polygon.io/dashboard/api-keys         (free tier)
# Finnhub:         https://finnhub.io/dashboard                  (free tier)
ALPHA_VANTAGE_API_KEY=
POLYGON_API_KEY=
FINNHUB_API_KEY=

# Bearer token for remote MCP access at /api/mcp
# Generate: openssl rand -hex 32
MCP_TOKEN=

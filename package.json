{
  "name": "astroledger",
  "version": "0.7.0",
  "private": true,
  "scripts": {
    "dev": "next dev -p 5050",
    "dev:demo": "next dev -p 5055",
    "build": "next build",
    "build:prod": "tsx scripts/validate-env.ts && next build",
    "start": "next start -p 5050",
    "start:demo": "next start -p 5055",
    "docker:build": "docker compose build astroledger",
    "docker:up": "docker compose up -d astroledger",
    "docker:down": "docker compose down",
    "docker:logs": "docker compose logs -f astroledger",
    "smoke": "tsx scripts/smoke-test.ts",
    "setup:check": "tsx scripts/setup-check.ts",
    "lint": "next lint",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:integration": "vitest run --config vitest.integration.config.ts",
    "test:all": "vitest run && vitest run --config vitest.integration.config.ts",
    "test:e2e": "playwright test",
    "test:e2e:multiuser": "playwright test --config playwright.multiuser.config.ts",
    "db:push": "prisma db push",
    "db:studio": "prisma studio",
    "db:seed": "tsx prisma/seed.ts",
    "postinstall": "patch-package",
    "seed:demo": "tsx scripts/seed-demo.ts",
    "detect": "tsx scripts/run-detection.ts",
    "mcp": "tsx mcp/server.ts",
    "llm:up": "powershell -ExecutionPolicy Bypass -File scripts/llm-up.ps1",
    "llm:down": "powershell -ExecutionPolicy Bypass -File scripts/llm-down.ps1"
  },
  "dependencies": {
    "@auth/prisma-adapter": "^2.7.4",
    "@modelcontextprotocol/sdk": "^1.0.4",
    "@prisma/adapter-better-sqlite3": "6.19.3",
    "@prisma/client": "6.19.3",
    "@simplewebauthn/browser": "^9.0.1",
    "@simplewebauthn/server": "^9.0.3",
    "adm-zip": "^0.5.17",
    "better-sqlite3-multiple-ciphers": "12.11.1",
    "dotenv": "^16.6.1",
    "mailparser": "^3.9.8",
    "next": "^15.0.3",
    "next-auth": "5.0.0-beta.25",
    "papaparse": "^5.4.1",
    "pdf-parse": "^2.4.5",
    "plaid": "^27.0.0",
    "react": "^19.0.0",
    "react-dom": "^19.0.0",
    "react-plaid-link": "^4.0.1",
    "recharts": "^2.13.3",
    "zod": "^3.23.8"
  },
  "devDependencies": {
    "@playwright/test": "^1.60.0",
    "@types/adm-zip": "^0.5.8",
    "@types/mailparser": "^3.4.6",
    "@types/node": "^22.9.1",
    "@types/papaparse": "^5.3.15",
    "@types/react": "^19.0.0",
    "@types/react-dom": "^19.0.0",
    "autoprefixer": "^10.4.20",
    "postcss": "^8.4.49",
    "patch-package": "^8.0.1",
    "prisma": "6.19.3",
    "tailwindcss": "^3.4.15",
    "tsx": "^4.19.2",
    "typescript": "^5.6.3",
    "vitest": "^2.1.9"
  },
  "overrides": {
    "@prisma/adapter-better-sqlite3": {
      "better-sqlite3": "npm:better-sqlite3-multiple-ciphers@12.11.1"
    }
  }
}
